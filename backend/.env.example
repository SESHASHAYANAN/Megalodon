# ── Required API Keys ─────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional API Keys ─────────────────────────────────────
# GitHub OAuth (for web UI)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Krea AI (image generation in App Creator)
KREA_API_KEY=

# json2video (video visualization)
JSON2VIDEO_API_KEY=

# ── Model Configuration (optional, defaults shown) ────────
# GEMINI_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_MODEL=deepseek/deepseek-r1
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Base URLs (optional) ──────────────────────────────────
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Generation Parameters (optional) ─────────────────────
# STAGE1_TEMPERATURE=0.1
# STAGE1_MAX_TOKENS=4096
# STAGE2_TEMPERATURE=0.2
# STAGE2_MAX_TOKENS=8192
# STAGE3_TEMPERATURE=0.25
# STAGE3_MAX_TOKENS=8192
